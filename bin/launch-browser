#!/usr/bin/env bash
# Manage a persistent Chrome/Chromium browser for agent use via CDP.
#
# Usage:
#   browser-agent            start browser (headed), print CDP endpoint when ready
#   browser-agent --stop     kill the browser
#   browser-agent --status   print running/stopped status
#
# Agents connect via: chromium.connectOverCDP('http://localhost:9222')

set -euo pipefail

CDP_PORT=9222
CDP_URL="http://localhost:${CDP_PORT}"
PROFILE_DIR="${HOME}/.local/share/browser-agent"

find_chrome() {
    if [[ "$(uname)" == "Darwin" ]]; then
        local mac_chrome="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
        if [[ -x "$mac_chrome" ]]; then
            echo "$mac_chrome"
            return
        fi
    fi
    for candidate in google-chrome google-chrome-stable chromium-browser chromium; do
        if command -v "$candidate" &>/dev/null; then
            echo "$candidate"
            return
        fi
    done
    # Fall back to Playwright's bundled Chromium
    if command -v bunx &>/dev/null || command -v npx &>/dev/null; then
        echo "__playwright__"
        return
    fi
    echo "" 
}

is_running() {
    curl -sf "${CDP_URL}/json/version" > /dev/null 2>&1
}

wait_for_cdp() {
    local attempts=20
    for ((i=0; i<attempts; i++)); do
        if is_running; then
            return 0
        fi
        sleep 0.5
    done
    return 1
}

cmd_status() {
    if is_running; then
        echo "running  ${CDP_URL}"
    else
        echo "stopped"
    fi
}

cmd_stop() {
    if ! is_running; then
        echo "Browser is not running." >&2
        exit 0
    fi
    local pid
    # Try platform-specific tools to find the PID bound to the CDP port
    if [[ -x /usr/sbin/lsof ]]; then
        pid=$(/usr/sbin/lsof -ti "tcp:${CDP_PORT}" 2>/dev/null | head -1)
    elif command -v lsof &>/dev/null; then
        pid=$(lsof -ti "tcp:${CDP_PORT}" 2>/dev/null | head -1)
    elif command -v fuser &>/dev/null; then
        pid=$(fuser "${CDP_PORT}/tcp" 2>/dev/null | awk '{print $1}')
    elif command -v ss &>/dev/null; then
        pid=$(ss -tlnp "sport = :${CDP_PORT}" 2>/dev/null | grep -oP 'pid=\K[0-9]+' | head -1)
    fi
    if [[ -n "${pid:-}" ]]; then
        kill "$pid"
        echo "Stopped (pid ${pid})."
    else
        echo "Could not determine PID; browser may still be running." >&2
        exit 1
    fi
}

cmd_start() {
    if is_running; then
        echo "${CDP_URL}"
        exit 0
    fi

    local chrome
    chrome=$(find_chrome)

    if [[ -z "$chrome" ]]; then
        echo "Error: No Chrome/Chromium binary found." >&2
        exit 1
    fi

    mkdir -p "$PROFILE_DIR"

    local args=(
        "--remote-debugging-port=${CDP_PORT}"
        "--user-data-dir=${PROFILE_DIR}"
        "--no-first-run"
        "--no-default-browser-check"
    )

    if [[ "$chrome" == "__playwright__" ]]; then
        local runner="bunx"
        command -v bunx &>/dev/null || runner="npx"
        $runner playwright open "${args[@]/#/}" &>/dev/null &
    else
        "$chrome" "${args[@]}" &>/dev/null &
    fi
    disown

    if wait_for_cdp; then
        echo "${CDP_URL}"
    else
        echo "Error: Browser did not become ready within 10s." >&2
        exit 1
    fi
}

case "${1:-}" in
    --stop)   cmd_stop ;;
    --status) cmd_status ;;
    *)        cmd_start ;;
esac
