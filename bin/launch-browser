#!/usr/bin/env bash
# Manage a persistent Playwright browser server for agent use.
#
# Usage:
#   launch-browser           start server, print WebSocket endpoint when ready
#   launch-browser --stop    stop the server
#   launch-browser --status  print running/stopped status and endpoint
#
# Agents connect with:
#   const browser = await chromium.connect(fs.readFileSync(STATE_FILE).trim())
# where STATE_FILE = ~/.local/share/browser-agent/ws-endpoint

set -euo pipefail

PROFILE_DIR="${HOME}/.local/share/browser-agent"
STATE_FILE="${PROFILE_DIR}/ws-endpoint"
PID_FILE="${PROFILE_DIR}/server.pid"
SERVER_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/launch-browser-server.mjs"

runner() {
    # Playwright's launchServer WS implementation requires Node; Bun's WS server is incompatible
    if command -v node &>/dev/null; then echo "node"
    elif command -v bun &>/dev/null; then echo "bun run"
    else echo "npx"; fi
}

is_running() {
    [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

get_endpoint() {
    [[ -f "$STATE_FILE" ]] && cat "$STATE_FILE"
}

wait_for_endpoint() {
    local attempts=20
    for ((i=0; i<attempts; i++)); do
        local ep
        ep=$(get_endpoint)
        if [[ -n "$ep" ]]; then
            echo "$ep"
            return 0
        fi
        sleep 0.5
    done
    return 1
}

cmd_status() {
    if is_running; then
        local ep
        ep=$(get_endpoint)
        echo "running  ${ep}"
    else
        echo "stopped"
    fi
}

cmd_stop() {
    if ! is_running; then
        echo "Browser server is not running." >&2
        exit 0
    fi
    kill "$(cat "$PID_FILE")"
    rm -f "$PID_FILE"
    echo "Stopped."
}

cmd_start() {
    if is_running; then
        get_endpoint
        exit 0
    fi

    mkdir -p "$PROFILE_DIR"

    # Run server script in background, capture its output (the ws endpoint)
    $(runner) "$SERVER_SCRIPT" &>/dev/null &
    echo $! > "$PID_FILE"
    disown

    if wait_for_endpoint; then
        :
    else
        echo "Error: Browser server did not become ready within 10s." >&2
        rm -f "$PID_FILE"
        exit 1
    fi
}

case "${1:-}" in
    --stop)   cmd_stop ;;
    --status) cmd_status ;;
    *)        cmd_start ;;
esac
