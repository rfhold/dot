#!/usr/bin/env bash
# Launch an interactive container with the current directory mounted at the same path
#
# Usage:
#   sandbox              # Interactive shell in container
#   sandbox <command>    # Run a command in the container
#
# Options:
#   -p, --port <port>    Expose a port (can be used multiple times)
#
# Mounts:
#   - Current directory at the same path (e.g., /Users/rfhold/dot)
#   - ~/.local/share/opencode for shared opencode session data
#   - Docker socket when available, for container builds from inside sandbox


set -euo pipefail

IMAGE="cr.holdenitdown.net/rfhold/dot"

# Detect host OS to select appropriate image tag
if [[ -f /etc/os-release ]] && grep -q '^ID=arch' /etc/os-release; then
    IMAGE="${IMAGE}:arch"
else
    IMAGE="${IMAGE}:latest"
fi
CURRENT_DIR="$(pwd)"
OPENCODE_DATA="${HOME}/.local/share/opencode"
DOCKER_SOCKET=""

if [[ "${DOCKER_HOST:-}" == unix://* ]]; then
    candidate_socket="${DOCKER_HOST#unix://}"
    if [[ -S "$candidate_socket" ]]; then
        DOCKER_SOCKET="$candidate_socket"
    fi
fi

if [[ -z "$DOCKER_SOCKET" && -S /var/run/docker.sock ]]; then
    DOCKER_SOCKET="/var/run/docker.sock"
fi

if [[ -z "$DOCKER_SOCKET" && -n "${XDG_RUNTIME_DIR:-}" && -S "$XDG_RUNTIME_DIR/docker.sock" ]]; then
    DOCKER_SOCKET="$XDG_RUNTIME_DIR/docker.sock"
fi

# Detect container engine - prefer podman, fall back to docker
if command -v podman &>/dev/null; then
    ENGINE=podman
elif command -v docker &>/dev/null; then
    ENGINE=docker
else
    echo "Error: No container engine found. Install podman or docker." >&2
    exit 1
fi

# Parse arguments
PORTS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        -p|--port)
            PORTS+=(-p "$2:$2")
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# Build mount arguments
MOUNTS=(
    -v "${CURRENT_DIR}:${CURRENT_DIR}"
    -w "${CURRENT_DIR}"
)

# Mount opencode data directory (create if doesn't exist)
if [[ ! -d "$OPENCODE_DATA" ]]; then
    mkdir -p "$OPENCODE_DATA"
fi
MOUNTS+=(-v "${OPENCODE_DATA}:/home/rfhold/.local/share/opencode")

ENV_VARS=()
if [[ -n "$DOCKER_SOCKET" ]]; then
    MOUNTS+=(-v "${DOCKER_SOCKET}:/var/run/docker.sock")
    ENV_VARS+=(-e DOCKER_HOST=unix:///var/run/docker.sock)
fi

# Determine command to run
if [[ $# -gt 0 ]]; then
    CMD=("$@")
else
    CMD=(fish)
fi

# Build engine-specific options
ENGINE_OPTS=()
if [[ "$ENGINE" == "podman" ]]; then
    # Keep host UID inside container (fixes permission issues without modifying files)
    ENGINE_OPTS+=(--userns=keep-id)
fi

RUN_OPTS=(--rm)
if [[ -t 0 && -t 1 ]]; then
    RUN_OPTS+=(-it)
fi

if [[ -n "$DOCKER_SOCKET" ]]; then
    docker_gid=$(stat -c '%g' "$DOCKER_SOCKET" 2>/dev/null || true)
    if [[ -n "$docker_gid" ]]; then
        ENGINE_OPTS+=(--group-add "$docker_gid")
    fi
fi

exec $ENGINE run "${RUN_OPTS[@]}" \
    ${ENGINE_OPTS[@]+"${ENGINE_OPTS[@]}"} \
    ${PORTS[@]+"${PORTS[@]}"} \
    ${ENV_VARS[@]+"${ENV_VARS[@]}"} \
    "${MOUNTS[@]}" \
    "$IMAGE" \
    "${CMD[@]}"
