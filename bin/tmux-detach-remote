#!/usr/bin/env bash

# tmux-detach-remote - Detach the remote tmux session when leaving a remote window
#
# Usage: tmux-detach-remote <current-session> <prev-session>
#
# Called by the client-session-changed hook. If prev-session is a remote
# session (contains "/"), look up the SSH host and detach all clients from
# that remote tmux session.

CURRENT_SESSION="$1"
PREV_SESSION="$2"

# Only act if we just left a remote session (name contains "/")
if [[ "$PREV_SESSION" != */* ]]; then
    exit 0
fi

# Don't detach if we're still in the same machine's sessions
PREV_MACHINE="${PREV_SESSION%%/*}"
CURRENT_MACHINE="${CURRENT_SESSION%%/*}"
if [[ "$PREV_MACHINE" == "$CURRENT_MACHINE" ]]; then
    exit 0
fi

REMOTE_SESSION="${PREV_SESSION#*/}"

# Look up SSH host and per-window stub session names from the previous session
# Each window connects via its own grouped stub session: "<session>--stub--<window>"
declare -A window_ssh_host
declare -A window_ssh_user
declare -A window_remote_session
declare -A window_remote_window

while IFS= read -r window; do
    w_host=$(tmux show-options -t "${PREV_SESSION}:${window}" -wqv @remote_host 2>/dev/null)
    w_user=$(tmux show-options -t "${PREV_SESSION}:${window}" -wqv @remote_user 2>/dev/null)
    w_rsess=$(tmux show-options -t "${PREV_SESSION}:${window}" -wqv @remote_session 2>/dev/null)
    w_rwin=$(tmux show-options -t "${PREV_SESSION}:${window}" -wqv @remote_window 2>/dev/null)
    [[ -n "$w_host" ]] && window_ssh_host["$window"]="$w_host"
    [[ -n "$w_user" ]] && window_ssh_user["$window"]="$w_user"
    [[ -n "$w_rsess" ]] && window_remote_session["$window"]="$w_rsess"
    [[ -n "$w_rwin" ]] && window_remote_window["$window"]="$w_rwin"
done < <(tmux list-windows -t "=${PREV_SESSION}" -F "#{window_name}" 2>/dev/null)

# Detach each window's stub session on the remote
for window in "${!window_ssh_host[@]}"; do
    SSH_HOST="${window_ssh_host[$window]}"
    SSH_USER="${window_ssh_user[$window]}"
    W_RSESS="${window_remote_session[$window]}"
    W_RWIN="${window_remote_window[$window]}"
    STUB_SESSION="${W_RSESS}--stub--${W_RWIN}"

    [[ -z "$SSH_HOST" || -z "$SSH_USER" || -z "$W_RSESS" || -z "$W_RWIN" ]] && continue

    ssh -o BatchMode=yes -o ConnectTimeout=3 "${SSH_USER}@${SSH_HOST}" \
        "tmux detach-client -s '${STUB_SESSION}' 2>/dev/null" &
done
