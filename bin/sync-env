#!/usr/bin/env bash

set -euo pipefail

REMOTE_HOST_DEFAULT="thinkpad.holdenitdown.net"
REMOTE_HOST="${SYNC_ENV_HOST:-$REMOTE_HOST_DEFAULT}"
REMOTE_USER="rfhold"
DOT_DIR="$HOME/dot"
ENV_DIR="$DOT_DIR/env"
SYNC_DIRS=("encrypted" "kubeconfig")

DRY_RUN=false
VERBOSE=false

usage() {
    echo "Usage: sync-env [--host HOST] [--dry-run] [--verbose]"
    exit 1
}

log() { echo "$*"; }
verbose() { $VERBOSE && echo "$*" || true; }
dry() { $DRY_RUN && echo "[dry-run] $*" || true; }

hash_file() {
    local path="$1"

    if command -v sha256sum &>/dev/null; then
        sha256sum "$path" | awk '{print $1}'
    elif command -v shasum &>/dev/null; then
        shasum -a 256 "$path" | awk '{print $1}'
    else
        echo "No SHA-256 checksum tool found (need sha256sum or shasum)." >&2
        exit 1
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            DRY_RUN=true
            ;;
        --verbose)
            VERBOSE=true
            ;;
        --host)
            shift
            [[ $# -gt 0 ]] || usage
            REMOTE_HOST="$1"
            ;;
        --host=*)
            REMOTE_HOST="${1#*=}"
            [[ -n "$REMOTE_HOST" ]] || usage
            ;;
        *)
            usage
            ;;
    esac
    shift
done

REMOTE="$REMOTE_USER@$REMOTE_HOST"

# Build a checksum map from lines of "checksum  path"
# Usage: parse_checksums <output_var_prefix> < <lines>
declare -A LOCAL_SUMS=()
declare -A REMOTE_SUMS=()

collect_local() {
    local rel_dir="$1"
    local abs_dir="$ENV_DIR/$rel_dir"
    local -a files=("$abs_dir"/*)

    [[ -d "$abs_dir" ]] || return 0
    [[ -e "${files[0]}" ]] || return 0

    for f in "${files[@]}"; do
        [[ -f "$f" ]] || continue
        [[ "$(basename "$f")" == ._* ]] && continue

        local rel="${rel_dir}/$(basename "$f")"
        local sum
        sum=$(hash_file "$f")
        LOCAL_SUMS["$rel"]="$sum"
        verbose "  local  $rel  $sum"
    done
}

collect_remote() {
    local rel_dir="$1"
    local remote_dir="dot/env/$rel_dir"
    local output
    output=$(ssh "$REMOTE" "REMOTE_DIR=$remote_dir REL_DIR=$rel_dir bash -s" <<'EOF'
set -euo pipefail

hash_file() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" | awk '{print $1}'
    elif command -v shasum >/dev/null 2>&1; then
        shasum -a 256 "$1" | awk '{print $1}'
    else
        echo "No SHA-256 checksum tool found on remote host." >&2
        exit 1
    fi
}

if [ ! -d "$REMOTE_DIR" ]; then
    exit 0
fi

shopt -s nullglob
for f in "$REMOTE_DIR"/*; do
    [ -f "$f" ] || continue
    case "$(basename "$f")" in
        ._*) continue ;;
    esac
    printf '%s  %s/%s\n' "$(hash_file "$f")" "$REL_DIR" "$(basename "$f")"
done
EOF
)

    while IFS= read -r line; do
        # Only process lines that look like checksum output (64 hex chars + space + path)
        [[ "$line" =~ ^([0-9a-f]{64})[[:space:]]+(.+)$ ]] || continue
        local sum="${BASH_REMATCH[1]}"
        local filename="${BASH_REMATCH[2]}"
        local rel="${rel_dir}/$(basename "$filename")"
        REMOTE_SUMS["$rel"]="$sum"
        verbose "  remote $rel  $sum"
    done <<< "$output"
}

transfer_to_remote() {
    local rel="$1"
    local local_path="$ENV_DIR/$rel"
    local remote_path="dot/env/$rel"
    local remote_dir="dot/env/$(dirname "$rel")"

    if $DRY_RUN; then
        dry "push $rel"
    else
        ssh "$REMOTE" "mkdir -p $remote_dir"
        scp -q "$local_path" "$REMOTE:$remote_path"
        log "  pushed $rel"
    fi
}

transfer_from_remote() {
    local rel="$1"
    local local_dir="$ENV_DIR/$(dirname "$rel")"
    local local_path="$ENV_DIR/$rel"
    local remote_path="dot/env/$rel"
    local expected_sum="${REMOTE_SUMS[$rel]:-}"

    if $DRY_RUN; then
        dry "pull $rel"
    else
        mkdir -p "$local_dir"
        scp -q "$REMOTE:$remote_path" "$local_path"
        if [[ -n "$expected_sum" ]]; then
            local actual
            actual=$(hash_file "$local_path")
            if [[ "$actual" != "$expected_sum" ]]; then
                log "  ERROR: checksum mismatch after pulling $rel (got $actual, expected $expected_sum)"
                rm -f "$local_path"
                return 1
            fi
        fi
        log "  pulled $rel"
    fi
}

prompt_conflict() {
    local rel="$1"
    local local_sum="${LOCAL_SUMS[$rel]}"
    local remote_sum="${REMOTE_SUMS[$rel]}"
    echo ""
    echo "CONFLICT: $rel"
    echo "  local:  $local_sum"
    echo "  remote: $remote_sum"
    if $DRY_RUN; then
        dry "would prompt: keep [l]ocal, [r]emote, or [s]kip"
        return
    fi
    local choice
    while true; do
        printf "  Keep [l]ocal, [r]emote, or [s]kip? " 
        read -r choice
        case "$choice" in
            l|L) transfer_to_remote "$rel"; return ;;
            r|R) transfer_from_remote "$rel"; return ;;
            s|S) log "  skipped $rel"; return ;;
            *) echo "  Enter l, r, or s." ;;
        esac
    done
}

# Collect all file info
log "Collecting local file checksums..."
for d in "${SYNC_DIRS[@]}"; do collect_local "$d"; done

log "Collecting remote file checksums from $REMOTE_HOST..."
for d in "${SYNC_DIRS[@]}"; do collect_remote "$d"; done

# Build unified set of all known relative paths
declare -A ALL_RELS=()
for k in "${!LOCAL_SUMS[@]}";  do ALL_RELS["$k"]=1; done
for k in "${!REMOTE_SUMS[@]}"; do ALL_RELS["$k"]=1; done

if [[ ${#ALL_RELS[@]} -eq 0 ]]; then
    log "No files found in either location."
    exit 0
fi

log ""
log "Syncing..."

push_count=0
pull_count=0
conflict_count=0
skip_count=0

for rel in $(echo "${!ALL_RELS[@]}" | tr ' ' '\n' | sort); do
    local_sum="${LOCAL_SUMS[$rel]:-}"
    remote_sum="${REMOTE_SUMS[$rel]:-}"

    if [[ -z "$local_sum" ]]; then
        log "  only remote: $rel → pulling"
        transfer_from_remote "$rel"
        pull_count=$((pull_count + 1))
    elif [[ -z "$remote_sum" ]]; then
        log "  only local:  $rel → pushing"
        transfer_to_remote "$rel"
        push_count=$((push_count + 1))
    elif [[ "$local_sum" == "$remote_sum" ]]; then
        verbose "  in sync:     $rel"
        skip_count=$((skip_count + 1))
    else
        prompt_conflict "$rel"
        conflict_count=$((conflict_count + 1))
    fi
done

log ""
if $DRY_RUN; then
    log "Dry run complete. pushed=$push_count pulled=$pull_count conflicts=$conflict_count skipped=$skip_count"
else
    log "Done. pushed=$push_count pulled=$pull_count conflicts=$conflict_count skipped=$skip_count"
fi
