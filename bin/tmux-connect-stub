#!/usr/bin/env bash

# tmux-connect-stub - after-select-window hook handler
#
# Usage: tmux-connect-stub <session> <window>
#
# Called by the after-select-window hook with session and window passed as
# tmux format expansions (#{session_name} #{window_name}) so the correct
# context is always used regardless of which client triggered the hook.

SESSION="$1"
WINDOW="$2"

if [[ -z "$SESSION" || -z "$WINDOW" ]]; then
    exit 0
fi

IS_REMOTE=$(tmux show-options -t "${SESSION}:${WINDOW}" -wqv @remote_stub 2>/dev/null)

if [[ "$IS_REMOTE" == "1" ]]; then
    PANE_CMD=$(tmux display-message -t "${SESSION}:${WINDOW}" -p "#{pane_current_command}" 2>/dev/null)

    # Wake only if the pane is in the initial idle state (tmux-stub-idle),
    # not during the post-disconnect read or while SSH is running
    if [[ "$PANE_CMD" == "tmux-stub-idle" ]]; then
        tmux send-keys -t "${SESSION}:${WINDOW}" "" Enter
    fi
fi
