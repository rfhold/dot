#!/usr/bin/env bash

# tmux-stub-window - Lazy SSH connector for remote stub windows
#
# Usage: tmux-stub-window <user> <host> <remote-session> <remote-window>
#
# Sits idle showing a connection prompt. When the after-select-window hook
# fires (or the user presses Enter), SSHes into the host and attaches to
# the specified tmux session, selecting the correct window.
# On disconnect the pane dies — no reconnect loop.

SSH_USER="$1"
SSH_HOST="$2"
REMOTE_SESSION="$3"
REMOTE_WINDOW="$4"

if [[ -z "$SSH_USER" || -z "$SSH_HOST" ]]; then
    echo "tmux-stub-window: missing arguments (user host [session] [window])" >&2
    exit 1
fi

connect() {
    if [[ -n "$REMOTE_SESSION" && -n "$REMOTE_WINDOW" ]]; then
        # Each stub window creates its own grouped session on the remote.
        # Grouped sessions share windows but have independent current-window
        # pointers, so selecting a window here doesn't affect other clients.
        #
        # We use new-session -d (not -A) to ensure the session exists without
        # accidentally attaching the terminal mid-script (new-session -A attaches
        # immediately when the session already exists, swallowing the rest).
        local stub_session="${REMOTE_SESSION}--stub--${REMOTE_WINDOW}"
        # Unset TMUX so the remote shell's tmux commands talk to the remote
        # tmux server, not the local one (SSH forwards $TMUX by default).
        ssh -t "${SSH_USER}@${SSH_HOST}" "
            unset TMUX
            tmux new-session -d -s '${REMOTE_SESSION}' 2>/dev/null
            tmux new-session -d -s '${stub_session}' -t '${REMOTE_SESSION}' 2>/dev/null
            tmux select-window -t '${stub_session}:${REMOTE_WINDOW}' 2>/dev/null
            tmux attach-session -t '${stub_session}'
            tmux kill-session -t '${stub_session}' 2>/dev/null
        "
    else
        ssh "${SSH_USER}@${SSH_HOST}"
    fi
}

prompt() {
    local msg="$1"
    printf "\033[2J\033[H"  # clear screen
    printf "  \033[38;5;208m%s\033[0m  →  \033[38;5;147m%s\033[0m" "$SSH_USER" "$SSH_HOST"
    if [[ -n "$REMOTE_SESSION" ]]; then
        printf "  \033[2m(%s)\033[0m" "$REMOTE_SESSION"
    fi
    printf "\n\n  \033[2m%s\033[0m\n\n  " "$msg"
}

# Initial idle state — block until woken by the hook.
# tmux-stub-idle is a named sentinel so tmux-connect-stub can distinguish
# this state from the post-disconnect read and only auto-connect here.
prompt "[not connected — select this window to connect]"
tmux-stub-idle

while true; do
    connect
    EXIT=$?

    if [[ $EXIT -eq 0 ]]; then
        # Clean disconnect — ask before reconnecting
        prompt "[disconnected — press enter to reconnect, q to close]"
    else
        # Error / unreachable — show exit code
        prompt "[connection lost (exit $EXIT) — press enter to retry, q to close]"
    fi

    read -r response
    [[ "$response" == "q" ]] && exit 0

    prompt "[connecting...]"
done
