{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "bunx",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser",
        "chromium"
      ],
      "enabled": false
    }
  },
  "instructions": [
    "CONTRIBUTING.md",
    "CLAUDE.md",
    ".cursor/rules/*.md"
  ],
  "permission": {
    "websearch": "deny",
    "bash": {
      "*": "allow",
      "pkexe *": "ask",
      "kill *": "ask",
      "pkill *": "ask",
      "gh *": "ask",
      "git *": "ask",
      "kubectl *": "ask",
      "pyinfra *": "ask",
      "uv run pyinfra *": "ask",
      "pulumi *": "ask",
      "helm *": "ask",
      "scp *": "ask",
      "ssh *": "ask",
      "aws *": "ask",
      "aws sts get-caller-identity*": "allow",
      "aws account get*": "allow",
      "aws account list*": "allow",
      "aws apigateway get*": "allow",
      "aws apigatewayv2 get*": "allow",
      "aws autoscaling describe*": "allow",
      "aws cloudformation describe*": "allow",
      "aws cloudformation list*": "allow",
      "aws cloudformation get-template*": "allow",
      "aws cloudfront describe*": "allow",
      "aws cloudfront get*": "allow",
      "aws cloudfront list*": "allow",
      "aws cloudtrail describe*": "allow",
      "aws cloudtrail get*": "allow",
      "aws cloudtrail list*": "allow",
      "aws cloudwatch describe*": "allow",
      "aws cloudwatch get*": "allow",
      "aws cloudwatch list*": "allow",
      "aws dynamodb describe*": "allow",
      "aws dynamodb list*": "allow",
      "aws ec2 describe*": "allow",
      "aws ecr describe*": "allow",
      "aws ecr get-authorization-token*": "ask",
      "aws ecr list*": "allow",
      "aws ecs describe*": "allow",
      "aws ecs list*": "allow",
      "aws eks describe*": "allow",
      "aws eks list*": "allow",
      "aws elasticache describe*": "allow",
      "aws elasticache list*": "allow",
      "aws elasticloadbalancing describe*": "allow",
      "aws events describe*": "allow",
      "aws events list*": "allow",
      "aws iam get*": "allow",
      "aws iam list*": "allow",
      "aws kms describe*": "allow",
      "aws kms get*": "allow",
      "aws kms list*": "allow",
      "aws lambda get*": "allow",
      "aws lambda list*": "allow",
      "aws logs describe*": "allow",
      "aws logs filter-log-events*": "allow",
      "aws logs get*": "allow",
      "aws logs list*": "allow",
      "aws organizations describe*": "allow",
      "aws organizations list*": "allow",
      "aws rds describe*": "allow",
      "aws rds list*": "allow",
      "aws route53 get*": "allow",
      "aws route53 list*": "allow",
      "aws s3 ls*": "allow",
      "aws s3api get-bucket*": "allow",
      "aws s3api get-public-access-block*": "allow",
      "aws s3api head-bucket*": "allow",
      "aws s3api head-object*": "allow",
      "aws s3api list*": "allow",
      "aws sns get*": "allow",
      "aws sns list*": "allow",
      "aws sqs get*": "allow",
      "aws sqs list*": "allow",
      "aws ssm describe*": "allow",
      "aws ssm get*": "allow",
      "aws ssm list*": "allow",
      "aws ssm get-parameter*": "ask",
      "aws ssm get-parameters*": "ask",
      "az *": "ask",
      "gcp *": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git tag*": "allow",
      "git blame*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git stash list*": "allow",
      "git describe*": "allow",
      "git rev-parse*": "allow",
      "git shortlog*": "allow",
      "git fetch*": "allow",
      "gh pull*": "allow",
      "gh push*": "allow",
      "gh push*-f": "ask",
      "gh push*--force": "ask",
      "gh pr list*": "allow",
      "gh pr checks*": "allow",
      "gh pr view*": "allow",
      "gh pr status*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh repo view*": "allow",
      "gh repo list*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh auth status*": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl explain *": "allow",
      "kubectl version *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl wait *": "allow",
      "kubectl diff *": "allow",
      "sudo *": "deny"
    }
  },
  "provider": {
    "homelab": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab",
      "options": {
        "baseURL": "https://agent-gateway.holdenitdown.net/v1"
      },
      "models": {
        "gemma-4-e2b": {
          "name": "Gemma 4 E2B",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B",
          "tool_call": true,
          "temperature": true,
          "options": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0.0,
            "presence_penalty": 0.0,
            "repetition_penalty": 1.0
          },
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "gpt-oss-120b": {
          "name": "GPT-OSS-120B",
          "headers": {
            "x-model-name": "gpt-oss-120b"
          },
          "reasoning": true
        }
      }
    }
  },
  "autoupdate": false,
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@tarquinen/opencode-dcp@beta",
    "re-search@git+ssh://git@git.holdenitdown.net/rfhold/re-search.git#opencode/v0.15.0",
    "rfhold-skills@git+ssh://git@git.holdenitdown.net/rfhold/skills.git#opencode/v0.1.1"
  ]
}
