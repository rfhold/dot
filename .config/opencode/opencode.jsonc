{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "bunx",
        "@playwright/mcp@latest",
        "--isolated",
        "--browser",
        "chromium"
      ],
      "enabled": false
    }
  },
  "instructions": [
    "CONTRIBUTING.md",
    "CLAUDE.md",
    ".cursor/rules/*.md"
  ],
  "permission": {
    "research_*": "deny",
    "websearch": "deny",
    "bash": {
      "*": "allow",
      "pkexe *": "ask",
      "kill *": "ask",
      "pkill *": "ask",
      "gh *": "ask",
      "git *": "ask",
      "kubectl *": "ask",
      "pyinfra *": "ask",
      "uv run pyinfra *": "ask",
      "pulumi *": "ask",
      "helm *": "ask",
      "scp *": "ask",
      "ssh *": "ask",
      "aws *": "ask",
      "az *": "ask",
      "gcp *": "ask",
      "git status*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git diff*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git tag*": "allow",
      "git blame*": "allow",
      "git ls-files*": "allow",
      "git ls-tree*": "allow",
      "git stash list*": "allow",
      "git describe*": "allow",
      "git rev-parse*": "allow",
      "git shortlog*": "allow",
      "git fetch*": "allow",
      "gh pull*": "allow",
      "gh push*": "allow",
      "gh push*-f": "ask",
      "gh push*--force": "ask",
      "gh pr list*": "allow",
      "gh pr checks*": "allow",
      "gh pr view*": "allow",
      "gh pr status*": "allow",
      "gh issue list*": "allow",
      "gh issue view*": "allow",
      "gh repo view*": "allow",
      "gh repo list*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh auth status*": "allow",
      "kubectl get *": "allow",
      "kubectl describe *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "kubectl api-resources *": "allow",
      "kubectl explain *": "allow",
      "kubectl version *": "allow",
      "kubectl cluster-info *": "allow",
      "kubectl wait *": "allow",
      "kubectl diff *": "allow",
      "sudo *": "deny"
    }
  },
  "provider": {
    "homelab": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Homelab",
      "options": {
        "baseURL": "https://agent-gateway.holdenitdown.net/v1"
      },
      "models": {
        "gemma-4-e2b": {
          "name": "Gemma 4 E2B",
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "qwen3.6-35b-a3b": {
          "name": "Qwen3.6 35B A3B",
          "tool_call": true,
          "temperature": true,
          "options": {
            "temperature": 0.6,
            "top_p": 0.95,
            "top_k": 20,
            "min_p": 0.0,
            "presence_penalty": 0.0,
            "repetition_penalty": 1.0
          },
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },
  "autoupdate": false,
  "plugin": [
    "@franlol/opencode-md-table-formatter@0.0.3",
    "@tarquinen/opencode-dcp@beta",
    "re-search@git+ssh://git@git.holdenitdown.net/rfhold/re-search.git#opencode/v0.6.0",
    "rfhold-skills@git+ssh://git@git.holdenitdown.net/rfhold/skills.git#opencode/v0.1.1"
  ]
}
