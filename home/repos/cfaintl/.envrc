export CLAUDE_CONFIG_DIR="$HOME/repos/cfaintl/.agents"
export OPENCODE_CONFIG_DIR="$HOME/repos/cfaintl/.agents"
export OPENCODE_CONFIG="$HOME/repos/cfaintl/.agents/opencode.jsonc"
export NPM_CONFIG_USERCONFIG="$HOME/.config/npm/cfaintl-npmrc"
export npm_config_userconfig="$NPM_CONFIG_USERCONFIG"
export PNPM_CONFIG_USERCONFIG="$NPM_CONFIG_USERCONFIG"
export NPM_TOKEN=$(sed -n 's/.*:_authToken=//p' "$HOME/.config/npm/cfaintl-npmrc" 2>/dev/null)
